---
import addSvg from "/public/icons/add.svg?raw";
import minusSvg from "/public/icons/minus.svg?raw";
import multiplySvg from "/public/icons/multiply.svg?raw";
import divideSvg from "/public/icons/divide.svg?raw";

const icons = [
  { name: "plus", svg: addSvg },
  { name: "minus", svg: minusSvg },
  { name: "multiply", svg: multiplySvg },
  { name: "divide", svg: divideSvg },
];

const col1 = icons;
const col2 = [...icons].reverse();
const col3 = icons;
const col4 = [...icons].reverse();

function loop(list) {
  // 返回两遍，并给每个生成唯一 key，避免重复 id
  return [...list, ...list].map((it, i) => ({
    ...it,
    key: `${it.name}-${i}`, // 唯一
    domId: `card_${it.name}-${i}`, // 唯一 DOM id
  }));
}
---

<section class="ig">
  <div class="ig-panel">
    <div class="ig-grid">
      <div class="ig-col up" style="--dur: 18s;">
        <div class="ig-track">
          {
            loop(col1).map((it) => (
              <div class="ig-tile">
                <div
                  id={it.domId}
                  class="card-icon"
                  set:html={it.svg}
                  aria-label={it.name}
                />
              </div>
            ))
          }
        </div>
      </div>

      <div class="ig-col down" style="--dur: 22s;">
        <div class="ig-track">
          {
            loop(col2).map((it) => (
              <div class="ig-tile">
                <div
                  id={it.domId}
                  class="card-icon"
                  set:html={it.svg}
                  aria-label={it.name}
                />
              </div>
            ))
          }
        </div>
      </div>

      <div class="ig-col up" style="--dur: 20s;">
        <div class="ig-track">
          {
            loop(col3).map((it) => (
              <div class="ig-tile">
                <div
                  id={it.domId}
                  class="card-icon"
                  set:html={it.svg}
                  aria-label={it.name}
                />
              </div>
            ))
          }
        </div>
      </div>

      <div class="ig-col down" style="--dur: 24s;">
        <div class="ig-track">
          {
            loop(col4).map((it) => (
              <div class="ig-tile">
                <div
                  id={it.domId}
                  class="card-icon"
                  set:html={it.svg}
                  aria-label={it.name}
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
<style>
  .ig {
    width: 100%;
    padding: 0;
  }

  .ig-panel {
    width: 100%;
    height: 380px;
    border-radius: 18px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: rgba(241, 248, 250, 0.6);
    overflow: hidden;
    position: relative;
  }

  /* 上下雾化遮罩 */
  .ig-panel::before,
  .ig-panel::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    height: 110px;
    z-index: 5;
    pointer-events: none;
  }
  .ig-panel::before {
    top: 0;
    background: linear-gradient(
      to bottom,
      rgba(241, 248, 250, 0.95),
      rgba(241, 248, 250, 0)
    );
  }
  .ig-panel::after {
    bottom: 0;
    background: linear-gradient(
      to top,
      rgba(241, 248, 250, 0.95),
      rgba(241, 248, 250, 0)
    );
  }

  /* 4 列布局（每列 92px） */
  .ig-grid {
    height: 100%;
    display: grid;
    grid-template-columns: repeat(4, 92px);
    gap: 18px;
    justify-content: center;
    align-items: stretch;
    padding: 22px 18px;
  }

  /* 每列是一个滚动窗口 */
  .ig-col {
    height: 100%;
    overflow: hidden;
  }

  /* 竖向滚动必须用 flex-column */
  .ig-track {
    display: flex;
    flex-direction: column;
    gap: 18px;
    will-change: transform;
    animation-duration: var(--dur, 20s);
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }

  .ig-col.up .ig-track {
    animation-name: ig-up;
  }
  .ig-col.down .ig-track {
    animation-name: ig-down;
  }

  @keyframes ig-up {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-50%);
    }
  }
  @keyframes ig-down {
    from {
      transform: translateY(-50%);
    }
    to {
      transform: translateY(0);
    }
  }

  .ig-tile {
    width: 72px;
    height: 72px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 10px 26px rgba(15, 23, 42, 0.08);
    display: grid;
    place-items: center;
  }

  /* inline svg 容器 */
  .card-icon {
    width: 46px;
    height: 46px;
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  /* 让 svg 跟随容器 */
  .card-icon :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* dim columns */
  .ig-col:nth-child(1),
  .ig-col:nth-child(4) {
    opacity: 0.85;
  }
</style>
