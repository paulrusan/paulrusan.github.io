---
/**
 * OrbitCard.astro (inline SVG version - Scheme A)
 * - Uses wrapper IDs (card_plus/card_minus/...) to "identify elements"
 * - Renders SVG inline via set:html so you can animate/target them
 * - Keeps icons upright while orbit rotates on hover
 */

import addSvg from "/public/icons/add.svg?raw";
import minusSvg from "/public/icons/minus.svg?raw";
import multiplySvg from "/public/icons/multiply.svg?raw";
import divideSvg from "/public/icons/divide.svg?raw";
import accSvg from "/public/icons/acc.svg?raw";

const icons = [
  { id: "card_plus", svg: addSvg, angle: 45, r: 60 },
  { id: "card_minus", svg: minusSvg, angle: 135, r: 60 },
  { id: "card_multiply", svg: multiplySvg, angle: 225, r: 60 },
  { id: "card_divide", svg: divideSvg, angle: 315, r: 60 },
];
---

<div class="orbit-card">
  <div class="orbit-top">
    <!-- “可见窗口”：只显示上半部分，下面会被裁掉 -->
    <div class="orbit-clip">
      <div class="rings" aria-hidden="true">
        <div class="ring ring-1"></div>
        <div class="ring ring-2"></div>
        <div class="ring ring-3"></div>
        <div class="ring ring-4"></div>
      </div>

      <!-- 旋转层：hover 才转 -->
      <div class="orbit-rot">
        {
          icons.map((it) => (
            <div class="orb" style={`--a:${it.angle}deg; --r:${it.r}px;`}>
              <div class="icon">
                <div class="icon-box" id={it.id} aria-label={it.id}>
                  <div class="icon-svg" set:html={it.svg} />
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <!-- center icon (NOT rotating) -->
      <div class="icon icon-center">
        <div class="icon-box" id="icon_center" aria-label="Accountium">
          <div class="icon-svg" set:html={accSvg} />
        </div>
      </div>
    </div>

    <div class="text">
      <div class="title">Seamless integrations</div>
      <div class="desc">
        Seamlessly connect your favorite apps and platforms with our powerful
        integrations.
      </div>
    </div>
  </div>

  <style>
    .orbit-card {
      width: 360px;
      border-radius: 22px;
      background: #fff;
      border: 1px solid rgba(15, 23, 42, 0.08);
      box-shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
      overflow: hidden;
      font-family:
        ui-sans-serif,
        system-ui,
        -apple-system,
        Segoe UI,
        Roboto,
        Arial,
        "PingFang SC",
        "Hiragino Sans GB",
        "Microsoft YaHei",
        sans-serif;
    }

    .orbit-top {
      padding: 18px 18px 0;
      background: linear-gradient(
        180deg,
        rgba(15, 23, 42, 0.03),
        rgba(15, 23, 42, 0)
      );
      position: relative;
    }

    .orbit-clip {
      position: relative;
      height: 210px;
      overflow: hidden;
      border-radius: 18px;
    }

    /* layers positioned around a slightly lower center */
    .rings,
    .orbit-rot,
    .icon-center {
      position: absolute;
      left: 52%;
      top: 55%;
      transform: translate(-50%, -50%);
    }

    /* center icon tweak */
    .icon-center {
      left: 43% !important;
      top: 42% !important;
    }

    /* rings */
    .rings {
      width: 250px;
      height: 250px;
      pointer-events: none;
    }

    .ring {
      position: absolute;
      inset: 0;
      border-radius: 999px;
      border: 4px dotted rgba(1, 1, 1, 0.12);
      opacity: 0.55;
    }
    .ring-1 {
      transform: scale(0.8);
      opacity: 0.6;
    }
    .ring-2 {
      transform: scale(0.58);
      opacity: 0.45;
    }
    .ring-3 {
      transform: scale(0.36);
      opacity: 0.3;
    }
    .ring-4 {
      transform: scale(1);
      opacity: 0.55;
    }

    /* orbit rotation (paused until hover) */
    .orbit-rot {
      width: 360px;
      height: 360px;
      transform: translate(-50%, -50%);
      transform-origin: 50% 50%;
      animation: spin 18s linear infinite;
      animation-play-state: paused;
    }
    .orbit-card:hover .orbit-rot {
      animation-play-state: running;
    }

    /* orbit items: place around circle */
    .orb {
      position: absolute;
      left: 50%;
      top: 50%;
      width: 0;
      height: 0;
      transform: rotate(var(--a)) translateX(var(--r));
      transform-origin: 0 0;
    }

    /* icon card */
    .icon {
      width: 58px;
      height: 58px;
      border-radius: 16px;
      background: #fff;
      border: 1px solid rgba(15, 23, 42, 0.1);
      box-shadow:
        0 12px 26px rgba(15, 23, 42, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 0.9);
      display: flex;
      align-items: center;
      justify-content: center;

      /* counter-rotate to keep upright (paused until hover) */
      animation: counterspin 18s linear infinite;
      animation-play-state: paused;
    }

    /* ✅ only orbit icons counterspin on hover (NOT the center) */
    .orbit-card:hover .orbit-rot .icon {
      animation-play-state: running;
    }

    /* center icon stays fixed */
    .icon-center {
      width: 62px;
      height: 62px;
      border-radius: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #fff;
      border: 1px solid rgba(15, 23, 42, 0.1);
      box-shadow:
        0 12px 26px rgba(15, 23, 42, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 0.9);
    }

    /* 只负责“识别”的外层，不负责尺寸 */
    .icon-box {
      width: 46px;
      height: 46px;
      display: grid;
      place-items: center;
      overflow: hidden; /* 关键：不让 base64 image 溢出 */
    }

    /* 只负责塞 svg 的内层 */
    .icon-svg {
      width: 100%;
      height: 100%;
      overflow: hidden;
    }

    /* 强制 inline svg 按盒子缩放 */
    .icon-svg :global(svg) {
      width: 100% !important;
      height: 100% !important;
      display: block;
      max-width: 100%;
      max-height: 100%;
    }

    /* 如果 Inkscape 写死了 width/height，这句能压住 */
    .icon-svg :global(svg image) {
      width: 100% !important;
      height: 100% !important;
    }
    .text {
      padding: 14px 18px 18px;
      border-top: 1px solid rgba(15, 23, 42, 0.06);
    }
    .title {
      font-size: 16px;
      font-weight: 850;
      color: rgba(15, 23, 42, 0.92);
    }
    .desc {
      margin-top: 8px;
      font-size: 14px;
      line-height: 1.55;
      color: rgba(15, 23, 42, 0.65);
    }

    /* animations */
    @keyframes spin {
      from {
        transform: translate(-50%, -50%) rotate(0deg);
      }
      to {
        transform: translate(-50%, -50%) rotate(360deg);
      }
    }
    @keyframes counterspin {
      from {
        transform: rotate(0deg);
      }
      to {
        transform: rotate(-360deg);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .orbit-rot,
      .icon {
        animation: none;
      }
    }
  </style>
</div>
