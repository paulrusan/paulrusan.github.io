---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const values = [
  {
    icon: '✦',
    title: 'Accuracy first',
    description: 'Wrong numbers cost businesses money and trust. Every feature we ship is tested for precision before speed.',
  },
  {
    icon: '◈',
    title: 'Simple by design',
    description: 'Accounting is already complex. Our job is to make the software feel effortless — even for non-accountants.',
  },
  {
    icon: '⬡',
    title: 'AI with guardrails',
    description: 'We believe AI should augment human judgment, not replace it. Everything our AI does can be reviewed and corrected.',
  },
  {
    icon: '⊙',
    title: 'Security as a foundation',
    description: 'Financial data is sensitive. We are SOC 2 Type II certified, encrypted end-to-end, and audited annually.',
  },
];
---

<BaseLayout
  title="About"
  description="Learn about Accountium — our mission to make AI-powered accounting accessible to every business."
>
  <!-- Page Hero -->
  <section class="page-hero section-sm" aria-label="About us">
    <div class="container page-hero-inner">
      <p class="section-label">About</p>
      <h1>Built for the modern CFO</h1>
      <p class="page-subline">
        Great businesses deserve better accounting tools. Accountium uses advanced technology to replace outdated systems with a smarter, faster, and more intuitive way to manage your finances.
      </p>
    </div>
  </section>

  <!-- Mission -->
  <section class="mission-section section-sm" aria-labelledby="mission-heading">
    <div class="container">
      <div class="feat-divider" aria-hidden="true"></div>
      <p class="section-label mission-label">Our mission</p>
      <div class="mission-inner glass-card">
        <div class="mission-content">
          <h2 id="mission-heading">
            Make financial clarity<br />accessible to every business.
          </h2>
          <p>
            Most accounting software treats Advanced Technology as a bolt-on feature. We built Accountium
            with Advanced Technology at the center — so the system gets smarter the longer you use it,
            automatically adapting to your business model, industry, and preferences.
          </p>
          <p>
            We believe that when financial operations are truly automated, finance teams can
            stop firefighting and start driving strategy. That's the future we're building.
          </p>
        </div>
        <div class="mission-stats">
          <div class="stat">
            <span class="stat-value">2,400+</span>
            <span class="stat-label">Finance teams</span>
          </div>
          <div class="stat">
            <span class="stat-value">98.7%</span>
            <span class="stat-label">AI accuracy rate</span>
          </div>
          <div class="stat">
            <span class="stat-value">$2.4B+</span>
            <span class="stat-label">Transactions processed</span>
          </div>
          <div class="stat">
            <span class="stat-value">4.9/5</span>
            <span class="stat-label">Average rating</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="vals-section section-sm" aria-labelledby="values-heading">
    <div class="container">
      <div class="feat-divider" aria-hidden="true"></div>
      <div class="vals-header">
        <p class="section-label">Our values</p>
        <h2 id="values-heading">What guides every decision</h2>
      </div>
    </div>
    <div class="val-list">
      {values.map((v, i) => (
        <Fragment>
          {i > 0 && <div class="feat-divider" aria-hidden="true"></div>}
          <div class={`val-row${i % 2 === 1 ? ' val-row--alt' : ''}`}>
            <div class="val-media">
              <span class="val-icon" aria-hidden="true">{v.icon}</span>
            </div>
            <div class="val-body">
              <h3 class="val-title">{v.title}</h3>
              <p class="val-desc">{v.description}</p>
            </div>
          </div>
        </Fragment>
      ))}
    </div>
  </section>

  <!-- Security Note -->
  <div class="feat-divider" aria-hidden="true"></div>
  <section id="security" class="section-sm" aria-labelledby="security-heading">
    <div class="container">
      <div class="security-inner glass-card">
        <h2 id="security-heading">
          Security & compliance
        </h2>
        <div class="security-grid">
          {[
            { label: 'SOC 2 Type II',         desc: 'Independently audited annually' },
            { label: 'TLS 1.3 Encryption',    desc: 'All data encrypted in transit' },
            { label: 'AES-256 at Rest',        desc: 'Database-level encryption' },
            { label: 'GDPR Compliant',         desc: 'Full data portability & deletion' },
            { label: '99.9% Uptime SLA',       desc: 'On Growth & Scale plans' },
            { label: 'Role-Based Access',      desc: 'Granular permissions per user' },
          ].map((item) => (
            <div class="security-item">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <path d="M9 1.5L2.25 4.5v5.25c0 3.938 2.888 7.613 6.75 8.25 3.862-.637 6.75-4.312 6.75-8.25V4.5L9 1.5z" stroke="var(--color-green)" stroke-width="1.5" stroke-linejoin="round"/>
                <path d="M6 9l2 2 4-4" stroke="var(--color-green)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div>
                <p class="security-label">{item.label}</p>
                <p class="security-desc">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="feat-divider" aria-hidden="true"></div>

  <CTASection
    headline="Want to learn more?"
    subline="Reach out — we'd love to show you around."
    ctaLabel="Try now"
    ctaHref="https://www.myaccountium.ca/Account/SignIn"
    secondaryLabel=""
  />
</BaseLayout>

<style>
  .page-hero {
    padding-top: calc(var(--header-height) + var(--space-16));
  }

  .page-hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-4);
  }

  .page-hero-inner h1 {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .page-subline {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 52ch;
    margin: 0;
  }

  /* Mission */
  .mission-label {
    display: flex;
    justify-content: center;
    margin: 0 auto var(--space-6);
  }

  .mission-inner {
    padding: var(--space-12) var(--space-8);
    border-radius: var(--radius-lg);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-12);
    align-items: center;
  }

  .mission-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 560px;
  }

  .mission-content h2 {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .mission-content p {
    max-width: none;
  }

  .mission-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    flex-shrink: 0;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .stat-value {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
  }

  .stat-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }

  /* Values */
  .vals-section {
    padding-bottom: var(--space-4);
  }

  .vals-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-10);
  }

  .vals-header h2 {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .val-list {
    padding: var(--space-4) 0;
  }

  .val-row {
    display: flex;
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
    max-width: 1100px;
    margin: 0 auto var(--space-16);
    padding: 0 var(--space-6);
  }

  .val-row--alt {
    flex-direction: row-reverse;
  }

  .val-media {
    flex: 0 0 48%;
    border-radius: 20px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 240px;
  }

  .val-icon {
    font-size: 5rem;
    color: var(--color-accent);
    line-height: 1;
  }

  .val-body {
    flex: 1;
    min-width: 0;
  }

  .val-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 var(--space-4);
    color: var(--color-text);
  }

  .val-desc {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text);
    margin: 0;
    max-width: 46ch;
  }

  .feat-divider {
    width: 1px;
    height: 64px;
    background: linear-gradient(to bottom, transparent, var(--color-accent), transparent);
    margin: 0 auto var(--space-4);
  }

  /* Security */
  .security-inner {
    padding: var(--space-10) var(--space-8);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .security-inner h2 {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    text-align: center;
  }

  .security-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .security-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .security-item svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .security-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 2px;
    max-width: none;
    margin: 0 0 2px;
  }

  .security-desc {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    max-width: none;
    margin: 0;
  }

  /* Strip CTA card background on this page */
  :global(.cta-section .cta-inner) {
    background: transparent;
    border: none;
    box-shadow: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }
  :global(.cta-section .cta-glow) {
    display: none;
  }

  @media (max-width: 900px) {
    .mission-inner { grid-template-columns: 1fr; }
    .mission-stats { grid-template-columns: repeat(4, 1fr); }
    .security-grid { grid-template-columns: repeat(2, 1fr); }
    .val-row,
    .val-row--alt { flex-direction: column; gap: var(--space-6); margin-bottom: var(--space-12); }
    .val-media { flex: unset; width: 100%; min-height: 200px; }
    .val-desc { max-width: 100%; }
  }

  @media (max-width: 600px) {
    .mission-stats { grid-template-columns: repeat(2, 1fr); }
    .security-grid { grid-template-columns: 1fr; }
  }
</style>
