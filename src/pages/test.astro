---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout title="Design Test" description="Component and element test page">

  <!-- ── Page Header ───────────────────────────────────────── -->
  <section class="b4s2s1 page-hero">
    <div class="b4s2s1-inner">
      <span class="label">◈ Design System</span>
      <h1>Test Page</h1>
      <p>A sandbox for testing UI elements, components, cards, lists, and formatting patterns before using them in production pages.</p>
    </div>
  </section>

  <!-- ── Logo Strip (Superior-style) ─────────────────────── -->
  <section class="logo-strip-section">
    <p class="logo-strip-label">Trusted by leading teams</p>
    <div class="logo-strip">
      <div class="logo-chip"><span class="logo-wordmark">Stripe</span></div>
      <div class="logo-chip"><span class="logo-wordmark">Shopify</span></div>
      <div class="logo-chip"><span class="logo-wordmark">HubSpot</span></div>
      <div class="logo-chip"><span class="logo-wordmark">Plaid</span></div>
      <div class="logo-chip"><span class="logo-wordmark">Notion</span></div>
      <div class="logo-chip"><span class="logo-wordmark">Linear</span></div>
      <div class="logo-chip"><span class="logo-wordmark">Vercel</span></div>
      <div class="logo-chip"><span class="logo-wordmark">Figma</span></div>
    </div>
  </section>

  <!-- ── Logo Strip — Scrolling Marquee variant ────────────── -->
  <section class="logo-strip-section logo-strip-section--marquee">
    <p class="logo-strip-label">Scrolling marquee variant</p>
    <div class="marquee-track" aria-hidden="true">
      <!-- Fade overlays — mask left & right edges as logos scroll -->
      <div class="marquee-fade marquee-fade--left"></div>
      <div class="marquee-fade marquee-fade--right"></div>
      <div class="marquee-inner">
        <div class="logo-chip"><span class="logo-wordmark">Stripe</span></div>
        <div class="logo-chip"><span class="logo-wordmark">Shopify</span></div>
        <div class="logo-chip"><span class="logo-wordmark">HubSpot</span></div>
        <div class="logo-chip"><span class="logo-wordmark">Plaid</span></div>
        <div class="logo-chip"><span class="logo-wordmark">Notion</span></div>
        <div class="logo-chip"><span class="logo-wordmark">Linear</span></div>
        <div class="logo-chip"><span class="logo-wordmark">Vercel</span></div>
        <div class="logo-chip"><span class="logo-wordmark">Figma</span></div>
        <!-- duplicate set for seamless loop -->
        <div class="logo-chip"><span class="logo-wordmark">Stripe</span></div>
        <div class="logo-chip"><span class="logo-wordmark">Shopify</span></div>
        <div class="logo-chip"><span class="logo-wordmark">HubSpot</span></div>
        <div class="logo-chip"><span class="logo-wordmark">Plaid</span></div>
        <div class="logo-chip"><span class="logo-wordmark">Notion</span></div>
        <div class="logo-chip"><span class="logo-wordmark">Linear</span></div>
        <div class="logo-chip"><span class="logo-wordmark">Vercel</span></div>
        <div class="logo-chip"><span class="logo-wordmark">Figma</span></div>
      </div>
    </div>
  </section>

  <!-- ── scr2: Chemical Formula Marquee ───────────────────── -->
  <section class="logo-strip-section logo-strip-section--marquee" id="scr2">
    <p class="logo-strip-label">scr2 — Chemical Formula Marquee</p>
    <div class="marquee-track" aria-hidden="true">
      <div class="marquee-fade marquee-fade--left"></div>
      <div class="marquee-fade marquee-fade--right"></div>
      <div class="marquee-inner">

        <!-- H₂O — cyan -->
        <div class="logo-chip scr2-chip" style="--c:#06b6d4">
          <svg viewBox="0 0 58 42" width="58" height="42" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
            <text x="23" y="17" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">O</text>
            <text x="2"  y="38" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">H</text>
            <text x="46" y="38" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">H</text>
            <line x1="11" y1="34" x2="26" y2="22"/>
            <line x1="34" y1="22" x2="47" y2="34"/>
          </svg>
          <span class="scr2-label">H₂O</span>
        </div>

        <!-- CO₂ — green -->
        <div class="logo-chip scr2-chip" style="--c:#22c55e">
          <svg viewBox="0 0 82 28" width="82" height="28" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
            <text x="2"  y="19" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">O</text>
            <text x="35" y="19" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">C</text>
            <text x="68" y="19" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">O</text>
            <line x1="13" y1="10" x2="34" y2="10"/>
            <line x1="13" y1="15" x2="34" y2="15"/>
            <line x1="44" y1="10" x2="67" y2="10"/>
            <line x1="44" y1="15" x2="67" y2="15"/>
          </svg>
          <span class="scr2-label">CO₂</span>
        </div>

        <!-- CH₄ — amber -->
        <div class="logo-chip scr2-chip" style="--c:#f59e0b">
          <svg viewBox="0 0 58 58" width="58" height="58" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
            <text x="24" y="33" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">C</text>
            <text x="23" y="11" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">H</text>
            <text x="23" y="55" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">H</text>
            <text x="2"  y="33" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">H</text>
            <text x="46" y="33" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">H</text>
            <line x1="29" y1="13" x2="29" y2="21"/>
            <line x1="29" y1="35" x2="29" y2="44"/>
            <line x1="10" y1="28" x2="22" y2="28"/>
            <line x1="36" y1="28" x2="46" y2="28"/>
          </svg>
          <span class="scr2-label">CH₄</span>
        </div>

        <!-- C₆H₆ benzene — purple -->
        <div class="logo-chip scr2-chip" style="--c:#a855f7">
          <svg viewBox="0 0 50 48" width="50" height="48" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="25,4 43,14 43,34 25,44 7,34 7,14"/>
            <circle cx="25" cy="24" r="10" stroke-width="1.3"/>
          </svg>
          <span class="scr2-label">C₆H₆</span>
        </div>

        <!-- NH₃ — red -->
        <div class="logo-chip scr2-chip" style="--c:#ef4444">
          <svg viewBox="0 0 62 44" width="62" height="44" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
            <text x="26" y="18" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">N</text>
            <text x="2"  y="40" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">H</text>
            <text x="26" y="40" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">H</text>
            <text x="50" y="40" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">H</text>
            <line x1="28" y1="21" x2="10" y2="32"/>
            <line x1="31" y1="21" x2="31" y2="32"/>
            <line x1="34" y1="21" x2="52" y2="32"/>
          </svg>
          <span class="scr2-label">NH₃</span>
        </div>

        <!-- NaCl — pink -->
        <div class="logo-chip scr2-chip" style="--c:#ec4899">
          <svg viewBox="0 0 80 32" width="80" height="32" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
            <text x="2"  y="22" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">Na</text>
            <text x="21" y="14" font-size="8"  font-weight="700" font-family="monospace" fill="currentColor" stroke="none">+</text>
            <text x="52" y="22" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">Cl</text>
            <text x="69" y="14" font-size="8"  font-weight="700" font-family="monospace" fill="currentColor" stroke="none">−</text>
            <line x1="30" y1="17" x2="36" y2="17" stroke-dasharray="2,2"/>
            <line x1="38" y1="17" x2="44" y2="17" stroke-dasharray="2,2"/>
            <line x1="46" y1="17" x2="51" y2="17" stroke-dasharray="2,2"/>
          </svg>
          <span class="scr2-label">NaCl</span>
        </div>

        <!-- C₂H₅OH ethanol — teal -->
        <div class="logo-chip scr2-chip" style="--c:#14b8a6">
          <svg viewBox="0 0 92 30" width="92" height="30" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
            <text x="2"  y="20" font-size="9" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">CH₃</text>
            <text x="34" y="20" font-size="9" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">CH₂</text>
            <text x="66" y="20" font-size="9" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">OH</text>
            <line x1="28" y1="15" x2="34" y2="15"/>
            <line x1="60" y1="15" x2="66" y2="15"/>
          </svg>
          <span class="scr2-label">C₂H₅OH</span>
        </div>

        <!-- H₂SO₄ — lime -->
        <div class="logo-chip scr2-chip" style="--c:#84cc16">
          <svg viewBox="0 0 60 60" width="60" height="60" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
            <text x="24" y="35" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">S</text>
            <text x="23" y="11" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">O</text>
            <line x1="27" y1="14" x2="28" y2="23"/>
            <line x1="31" y1="14" x2="32" y2="23"/>
            <text x="23" y="57" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">O</text>
            <line x1="27" y1="37" x2="28" y2="46"/>
            <line x1="31" y1="37" x2="32" y2="46"/>
            <text x="0"  y="35" font-size="9" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">HO</text>
            <line x1="17" y1="30" x2="23" y2="30"/>
            <text x="39" y="35" font-size="9" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">OH</text>
            <line x1="33" y1="30" x2="39" y2="30"/>
          </svg>
          <span class="scr2-label">H₂SO₄</span>
        </div>

        <!-- duplicate set for seamless loop -->
        <div class="logo-chip scr2-chip" style="--c:#06b6d4">
          <svg viewBox="0 0 58 42" width="58" height="42" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
            <text x="23" y="17" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">O</text>
            <text x="2"  y="38" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">H</text>
            <text x="46" y="38" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">H</text>
            <line x1="11" y1="34" x2="26" y2="22"/>
            <line x1="34" y1="22" x2="47" y2="34"/>
          </svg>
          <span class="scr2-label">H₂O</span>
        </div>
        <div class="logo-chip scr2-chip" style="--c:#22c55e">
          <svg viewBox="0 0 82 28" width="82" height="28" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
            <text x="2"  y="19" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">O</text>
            <text x="35" y="19" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">C</text>
            <text x="68" y="19" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">O</text>
            <line x1="13" y1="10" x2="34" y2="10"/>
            <line x1="13" y1="15" x2="34" y2="15"/>
            <line x1="44" y1="10" x2="67" y2="10"/>
            <line x1="44" y1="15" x2="67" y2="15"/>
          </svg>
          <span class="scr2-label">CO₂</span>
        </div>
        <div class="logo-chip scr2-chip" style="--c:#f59e0b">
          <svg viewBox="0 0 58 58" width="58" height="58" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
            <text x="24" y="33" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">C</text>
            <text x="23" y="11" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">H</text>
            <text x="23" y="55" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">H</text>
            <text x="2"  y="33" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">H</text>
            <text x="46" y="33" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">H</text>
            <line x1="29" y1="13" x2="29" y2="21"/>
            <line x1="29" y1="35" x2="29" y2="44"/>
            <line x1="10" y1="28" x2="22" y2="28"/>
            <line x1="36" y1="28" x2="46" y2="28"/>
          </svg>
          <span class="scr2-label">CH₄</span>
        </div>
        <div class="logo-chip scr2-chip" style="--c:#a855f7">
          <svg viewBox="0 0 50 48" width="50" height="48" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="25,4 43,14 43,34 25,44 7,34 7,14"/>
            <circle cx="25" cy="24" r="10" stroke-width="1.3"/>
          </svg>
          <span class="scr2-label">C₆H₆</span>
        </div>
        <div class="logo-chip scr2-chip" style="--c:#ef4444">
          <svg viewBox="0 0 62 44" width="62" height="44" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
            <text x="26" y="18" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">N</text>
            <text x="2"  y="40" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">H</text>
            <text x="26" y="40" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">H</text>
            <text x="50" y="40" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">H</text>
            <line x1="28" y1="21" x2="10" y2="32"/>
            <line x1="31" y1="21" x2="31" y2="32"/>
            <line x1="34" y1="21" x2="52" y2="32"/>
          </svg>
          <span class="scr2-label">NH₃</span>
        </div>
        <div class="logo-chip scr2-chip" style="--c:#ec4899">
          <svg viewBox="0 0 80 32" width="80" height="32" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
            <text x="2"  y="22" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">Na</text>
            <text x="21" y="14" font-size="8"  font-weight="700" font-family="monospace" fill="currentColor" stroke="none">+</text>
            <text x="52" y="22" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">Cl</text>
            <text x="69" y="14" font-size="8"  font-weight="700" font-family="monospace" fill="currentColor" stroke="none">−</text>
            <line x1="30" y1="17" x2="36" y2="17" stroke-dasharray="2,2"/>
            <line x1="38" y1="17" x2="44" y2="17" stroke-dasharray="2,2"/>
            <line x1="46" y1="17" x2="51" y2="17" stroke-dasharray="2,2"/>
          </svg>
          <span class="scr2-label">NaCl</span>
        </div>
        <div class="logo-chip scr2-chip" style="--c:#14b8a6">
          <svg viewBox="0 0 92 30" width="92" height="30" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
            <text x="2"  y="20" font-size="9" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">CH₃</text>
            <text x="34" y="20" font-size="9" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">CH₂</text>
            <text x="66" y="20" font-size="9" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">OH</text>
            <line x1="28" y1="15" x2="34" y2="15"/>
            <line x1="60" y1="15" x2="66" y2="15"/>
          </svg>
          <span class="scr2-label">C₂H₅OH</span>
        </div>
        <div class="logo-chip scr2-chip" style="--c:#84cc16">
          <svg viewBox="0 0 60 60" width="60" height="60" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
            <text x="24" y="35" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">S</text>
            <text x="23" y="11" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">O</text>
            <line x1="27" y1="14" x2="28" y2="23"/>
            <line x1="31" y1="14" x2="32" y2="23"/>
            <text x="23" y="57" font-size="11" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">O</text>
            <line x1="27" y1="37" x2="28" y2="46"/>
            <line x1="31" y1="37" x2="32" y2="46"/>
            <text x="0"  y="35" font-size="9" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">HO</text>
            <line x1="17" y1="30" x2="23" y2="30"/>
            <text x="39" y="35" font-size="9" font-weight="700" font-family="monospace" fill="currentColor" stroke="none">OH</text>
            <line x1="33" y1="30" x2="39" y2="30"/>
          </svg>
          <span class="scr2-label">H₂SO₄</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ── scr3: Mathematical Formula Marquee ───────────────── -->
  <section class="logo-strip-section logo-strip-section--marquee" id="scr3">
    <p class="logo-strip-label">scr3 — Mathematical Formula Marquee</p>
    <div class="marquee-track" aria-hidden="true">
      <div class="marquee-fade marquee-fade--left"></div>
      <div class="marquee-fade marquee-fade--right"></div>
      <div class="marquee-inner">

        <!-- E = mc² — violet -->
        <div class="logo-chip scr2-chip" style="--c:#8b5cf6">
          <svg viewBox="0 0 72 30" width="72" height="30" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <text x="2" y="21" font-size="13" font-weight="700" font-family="serif" fill="currentColor" stroke="none">E = mc</text>
            <text x="62" y="14" font-size="8" font-weight="700" font-family="serif" fill="currentColor" stroke="none">2</text>
          </svg>
          <span class="scr2-label">E=mc²</span>
        </div>

        <!-- a²+b²=c² — blue -->
        <div class="logo-chip scr2-chip" style="--c:#3b82f6">
          <svg viewBox="0 0 72 30" width="72" height="30" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <text x="2"  y="21" font-size="11" font-weight="700" font-family="serif" fill="currentColor" stroke="none">a</text>
            <text x="10" y="14" font-size="7"  font-weight="700" font-family="serif" fill="currentColor" stroke="none">2</text>
            <text x="16" y="21" font-size="11" font-weight="700" font-family="serif" fill="currentColor" stroke="none">+b</text>
            <text x="30" y="14" font-size="7"  font-weight="700" font-family="serif" fill="currentColor" stroke="none">2</text>
            <text x="36" y="21" font-size="11" font-weight="700" font-family="serif" fill="currentColor" stroke="none">=c</text>
            <text x="50" y="14" font-size="7"  font-weight="700" font-family="serif" fill="currentColor" stroke="none">2</text>
          </svg>
          <span class="scr2-label">a²+b²=c²</span>
        </div>

        <!-- F = ma — green -->
        <div class="logo-chip scr2-chip" style="--c:#22c55e">
          <svg viewBox="0 0 58 28" width="58" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <text x="2" y="20" font-size="13" font-weight="700" font-family="serif" fill="currentColor" stroke="none">F = ma</text>
          </svg>
          <span class="scr2-label">F=ma</span>
        </div>

        <!-- eⁱᵖ + 1 = 0 — amber (Euler's identity) -->
        <div class="logo-chip scr2-chip" style="--c:#f59e0b">
          <svg viewBox="0 0 80 30" width="80" height="30" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <text x="2"  y="21" font-size="13" font-weight="700" font-family="serif" fill="currentColor" stroke="none">e</text>
            <text x="12" y="13" font-size="8"  font-weight="700" font-family="serif" fill="currentColor" stroke="none">iπ</text>
            <text x="24" y="21" font-size="13" font-weight="700" font-family="serif" fill="currentColor" stroke="none">+ 1 = 0</text>
          </svg>
          <span class="scr2-label">Euler</span>
        </div>

        <!-- ∂f/∂x — orange (partial derivative) -->
        <div class="logo-chip scr2-chip" style="--c:#f97316">
          <svg viewBox="0 0 36 44" width="36" height="44" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <text x="4" y="17" font-size="11" font-weight="700" font-family="serif" fill="currentColor" stroke="none">∂f</text>
