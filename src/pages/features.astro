---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureCard from '../components/FeatureCard.astro';
import CTASection from '../components/CTASection.astro';
import { features } from '../data/features';
---

<BaseLayout
  title="Features"
  description="Explore Accountium's full feature set: AI bookkeeping, smart invoicing, real-time dashboards, tax prep, and more."
>
  <!-- Page Header -->
  <section class="page-hero section-sm" aria-label="Page header">
    <div class="container page-hero-inner">
      <p class="section-label">Features</p>
      <h1>The most powerful business platform.</h1>
      <p class="page-subline">
        Say goodbye to chaos and embrace a smoother workflow designed to help your team achieve more. Our app keeps you in touch and in control, giving you access to our services anytime, anywhere.
      </p>
    </div>
  </section>

  <!-- scr4: Financial Formula Marquee -->
  <section class="marquee-section" aria-hidden="true">
    <div class="marquee-track">
      <div class="marquee-fade marquee-fade--left"></div>
      <div class="marquee-fade marquee-fade--right"></div>
      <div class="marquee-inner">

        <div class="logo-chip fin-chip" style="--c:#8b5cf6">
          <span class="fin-text">ROI = (Gain − Cost) / Cost</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#22c55e">
          <span class="fin-text">Profit = Revenue − Expenses</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#3b82f6">
          <span class="fin-text">Gross Margin = (Rev − COGS) / Rev</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#f59e0b">
          <span class="fin-text">EPS = Net Income / Shares</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#f97316">
          <span class="fin-text">P/E = Price / EPS</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#06b6d4">
          <span class="fin-text">Current Ratio = Assets / Liabilities</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#14b8a6">
          <span class="fin-text">ROE = Net Income / Equity</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#ec4899">
          <span class="fin-text">Cash Flow = Inflows − Outflows</span>
        </div>

        <!-- duplicate set for seamless loop -->
        <div class="logo-chip fin-chip" style="--c:#8b5cf6">
          <span class="fin-text">ROI = (Gain − Cost) / Cost</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#22c55e">
          <span class="fin-text">Profit = Revenue − Expenses</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#3b82f6">
          <span class="fin-text">Gross Margin = (Rev − COGS) / Rev</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#f59e0b">
          <span class="fin-text">EPS = Net Income / Shares</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#f97316">
          <span class="fin-text">P/E = Price / EPS</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#06b6d4">
          <span class="fin-text">Current Ratio = Assets / Liabilities</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#14b8a6">
          <span class="fin-text">ROE = Net Income / Equity</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#ec4899">
          <span class="fin-text">Cash Flow = Inflows − Outflows</span>
        </div>

      </div>
    </div>
  </section>

  <!-- All Features Grid -->
  <section class="section-sm" aria-labelledby="all-features-heading">
    <div class="container">
      <h2 id="all-features-heading" class="sr-only">All features</h2>
      <div class="grid-3">
        {features.map((f) => (
          <FeatureCard {...f} />
        ))}
      </div>
    </div>
  </section>

  <!-- Integration Strip -->
  <section class="integrations-section section-sm" aria-labelledby="integrations-heading">
    <div class="container">
      <div class="integrations-inner glass-card">
        <h2 id="integrations-heading">Connects with your stack</h2>
        <p>
          Accountium integrates natively with the tools your team already uses.
          No manual CSV exports — just live, bi-directional data sync.
        </p>
        <div class="integration-tags" role="list">
          {['Stripe', 'Shopify', 'Plaid', 'HubSpot'].map((name) => (
            <span role="listitem" class="integration-tag">{name}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTASection
    headline="See it in action"
    subline="Accountium — One Platform. Any Industry. Any Team Size."
    secondaryLabel="Try Now"
    secondaryHref="https://www.myaccountium.ca/Account/SignIn"
    secondaryTarget="_blank"
  />
</BaseLayout>

<style>
  .page-hero {
    padding-top: calc(var(--header-height) + var(--space-16));
  }

  .page-hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-4);
  }

  .page-hero-inner h1 {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .page-subline {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 54ch;
    margin: 0;
  }

  /* ── scr4: Financial Formula Marquee ───────────────────── */
  .marquee-section {
    overflow: hidden;
    padding: var(--space-6) 0;
  }

  .marquee-track {
    overflow: hidden;
    width: 100%;
    position: relative;
  }

  .marquee-inner {
    display: flex;
    gap: var(--space-3);
    width: max-content;
    animation: marquee-scroll 55s linear infinite;
  }

  .marquee-inner .logo-chip { flex-shrink: 0; }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-inner { animation: none; justify-content: center; flex-wrap: wrap; }
  }

  .marquee-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    z-index: 2;
    pointer-events: none;
  }

  .marquee-fade--left {
    left: 0;
    background: linear-gradient(to right, var(--color-bg) 0%, transparent 100%);
  }

  .marquee-fade--right {
    right: 0;
    background: linear-gradient(to left, var(--color-bg) 0%, transparent 100%);
  }

  .logo-chip {
    background: #ffffff;
    border-radius: 12px;
    box-shadow:
      rgba(103, 103, 103, 0.08) 0px 0px 0px 1px,
      rgba(103, 103, 103, 0.08) 0px 2px 4px 0px;
    padding: 10px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .fin-chip {
    background: rgba(255, 255, 255, 0.3);
    box-shadow: none;
  }

  .fin-text {
    font-size: var(--text-sm);
    font-weight: 600;
    font-family: monospace;
    letter-spacing: 0.03em;
    white-space: nowrap;
    color: var(--c);
  }

  /* Integrations */
  .integrations-inner {
    padding: var(--space-12) var(--space-8);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-6);
    border-radius: var(--radius-lg);
  }

  .integrations-inner h2 {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .integrations-inner p {
    max-width: 50ch;
    margin: 0;
  }

  .integration-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
    margin-top: var(--space-2);
  }

  .integration-tag {
    padding: 6px 16px;
    border-radius: var(--radius-full);
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--color-border);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    transition: border-color var(--duration-fast), color var(--duration-fast);
  }

  .integration-tag:hover {
    border-color: var(--color-border-strong);
    color: var(--color-text-primary);
  }

  /* Screen-reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
</style>
