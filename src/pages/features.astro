---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout
  title="Features"
  description="Explore Accountium's full feature set: AI bookkeeping, smart invoicing, real-time dashboards, tax prep, and more."
>
  <!-- Page Header -->
  <section class="page-hero section-sm" aria-label="Page header">
    <div class="container page-hero-inner">
      <p class="section-label">Features</p>
      <h1>The most powerful business platform.</h1>
      <p class="page-subline">
        Say goodbye to chaos and embrace a smoother workflow designed to help your team achieve more. Our app keeps you in touch and in control, giving you access to our services anytime, anywhere.
      </p>
    </div>
  </section>

  <!-- scr4: Financial Formula Marquee -->
  <section class="marquee-section" aria-hidden="true">
    <div class="marquee-track">
      <div class="marquee-fade marquee-fade--left"></div>
      <div class="marquee-fade marquee-fade--right"></div>
      <div class="marquee-inner">

        <div class="logo-chip fin-chip" style="--c:#8b5cf6">
          <span class="fin-text">ROI = (Gain − Cost) / Cost</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#22c55e">
          <span class="fin-text">Profit = Revenue − Expenses</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#3b82f6">
          <span class="fin-text">Gross Margin = (Rev − COGS) / Rev</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#f59e0b">
          <span class="fin-text">EPS = Net Income / Shares</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#f97316">
          <span class="fin-text">P/E = Price / EPS</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#06b6d4">
          <span class="fin-text">Current Ratio = Assets / Liabilities</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#14b8a6">
          <span class="fin-text">ROE = Net Income / Equity</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#ec4899">
          <span class="fin-text">Cash Flow = Inflows − Outflows</span>
        </div>

        <!-- duplicate set for seamless loop -->
        <div class="logo-chip fin-chip" style="--c:#8b5cf6">
          <span class="fin-text">ROI = (Gain − Cost) / Cost</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#22c55e">
          <span class="fin-text">Profit = Revenue − Expenses</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#3b82f6">
          <span class="fin-text">Gross Margin = (Rev − COGS) / Rev</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#f59e0b">
          <span class="fin-text">EPS = Net Income / Shares</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#f97316">
          <span class="fin-text">P/E = Price / EPS</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#06b6d4">
          <span class="fin-text">Current Ratio = Assets / Liabilities</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#14b8a6">
          <span class="fin-text">ROE = Net Income / Equity</span>
        </div>
        <div class="logo-chip fin-chip" style="--c:#ec4899">
          <span class="fin-text">Cash Flow = Inflows − Outflows</span>
        </div>

      </div>
    </div>
  </section>

  <div class="feat-divider" aria-hidden="true"></div>

  <!-- All Features -->
  <section class="feat-list" aria-labelledby="all-features-heading">
    <h2 id="all-features-heading" class="sr-only">All features</h2>

    <!-- 1 · Sales -->
    <div class="feat-row">
      <div class="feat-media">
        <img src="/images/sales feature.svg" alt="Sales module" class="feat-svg" loading="lazy" />
      </div>
      <div class="feat-body">
        <h3 class="feat-name">Sales</h3>
        <p class="feat-desc">Create professional quotes and invoices in seconds, manage your customer relationships, and get a live view of your revenue pipeline — all from one place.</p>
        <ul class="feat-pills">
          <li>Invoices</li>
          <li>Estimates</li>
          <li>CRM</li>
        </ul>
      </div>
    </div>

    <div class="feat-divider" aria-hidden="true"></div>

    <!-- 2 · Purchases -->
    <div class="feat-row feat-row--alt">
      <div class="feat-media">
        <img src="/images/purchases.svg" alt="Purchases module" class="feat-svg" loading="lazy" />
      </div>
      <div class="feat-body">
        <h3 class="feat-name">Purchases</h3>
        <p class="feat-desc">Manage supplier bills, vendor accounts, and contractor payments with ease. Keep your payables under control and never miss a due date.</p>
        <ul class="feat-pills">
          <li>Bills</li>
          <li>Vendors</li>
          <li>Contractors</li>
        </ul>
      </div>
    </div>

    <div class="feat-divider" aria-hidden="true"></div>

    <!-- 3 · Payroll -->
    <div class="feat-row">
      <div class="feat-media">
        <img src="/images/payroll features.svg" alt="Payroll module" class="feat-svg" loading="lazy" />
      </div>
      <div class="feat-body">
        <h3 class="feat-name">Payroll</h3>
        <p class="feat-desc">Run payroll in a few clicks. Automate pay runs, handle statutory remittances, and keep schedules and reporting audit-ready at all times.</p>
        <ul class="feat-pills">
          <li>Payroll Run</li>
          <li>Remittance</li>
          <li>Schedules</li>
          <li>Reporting</li>
        </ul>
      </div>
    </div>

    <div class="feat-divider" aria-hidden="true"></div>

    <!-- 4 · Banking -->
    <div class="feat-row feat-row--alt">
      <div class="feat-media">
        <img src="/images/banking features.svg" alt="Banking module" class="feat-svg" loading="lazy" />
      </div>
      <div class="feat-body">
        <h3 class="feat-name">Banking</h3>
        <p class="feat-desc">Connect your bank accounts and import transactions automatically. Set smart rules and reconcile your books in minutes, not hours.</p>
        <ul class="feat-pills">
          <li>Feeds</li>
          <li>Rules</li>
          <li>Reconcile</li>
        </ul>
      </div>
    </div>

    <div class="feat-divider" aria-hidden="true"></div>

    <!-- 5 · Inventory -->
    <div class="feat-row">
      <div class="feat-media">
        <img src="/images/inventory.svg" alt="Inventory module" class="feat-svg" loading="lazy" />
      </div>
      <div class="feat-body">
        <h3 class="feat-name">Inventory</h3>
        <p class="feat-desc">Raise purchase orders, manage your item catalogue, and track stock levels in real time. Never run out of stock or over-order again.</p>
        <ul class="feat-pills">
          <li>Purchase Orders</li>
          <li>Items Management</li>
        </ul>
      </div>
    </div>

    <div class="feat-divider" aria-hidden="true"></div>

    <!-- 6 · Project Management -->
    <div class="feat-row feat-row--alt">
      <div class="feat-media">
        <img src="/images/project management.svg" alt="Project Management module" class="feat-svg" loading="lazy" />
      </div>
      <div class="feat-body">
        <h3 class="feat-name">Project Management</h3>
        <p class="feat-desc">Win more work with detailed bids, track project progress against budget, and invoice clients as milestones are reached — keeping every project profitable.</p>
        <ul class="feat-pills">
          <li>Bids</li>
          <li>Project Tracking</li>
          <li>Progress Invoicing</li>
        </ul>
      </div>
    </div>

    <div class="feat-divider" aria-hidden="true"></div>

    <!-- 7 · Reporting -->
    <div class="feat-row">
      <div class="feat-media">
        <img src="/images/reporting.svg" alt="Reporting module" class="feat-svg" loading="lazy" />
      </div>
      <div class="feat-body">
        <h3 class="feat-name">Reporting</h3>
        <p class="feat-desc">Turn raw numbers into clear insights. Generate financial statements, sales tax returns, and AR/AP summaries in real time — and export to PDF or Excel with a single click.</p>
        <ul class="feat-pills">
          <li>Financial Statements</li>
          <li>Sales Tax</li>
          <li>AR / AP</li>
        </ul>
      </div>
    </div>

  </section>

  <div class="feat-divider" aria-hidden="true"></div>

  <!-- Integration Strip -->
  <section class="integrations-section section-sm" aria-labelledby="integrations-heading">
    <div class="container">
      <div class="integrations-inner glass-card">
        <h2 id="integrations-heading">Connects with your stack</h2>
        <p>
          Accountium integrates natively with the tools your team already uses.
          No manual CSV exports — just live, bi-directional data sync.
        </p>
        <div class="integration-tags" role="list">
          {['Stripe', 'Shopify', 'Plaid', 'HubSpot'].map((name) => (
            <span role="listitem" class="integration-tag">{name}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="feat-divider" aria-hidden="true"></div>

  <CTASection
    headline="See it in action"
    subline="Accountium — One Platform. Any Industry. Any Team Size."
    secondaryLabel="Try Now"
    secondaryHref="https://www.myaccountium.ca/Account/SignIn"
    secondaryTarget="_blank"
  />
</BaseLayout>

<style>
  .page-hero {
    padding-top: calc(var(--header-height) + var(--space-16));
  }

  .page-hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-4);
  }

  .page-hero-inner h1 {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .page-subline {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 54ch;
    margin: 0;
  }

  /* ── scr4: Financial Formula Marquee ───────────────────── */
  .marquee-section {
    overflow: hidden;
    padding: var(--space-6) 0;
  }

  .marquee-track {
    overflow: hidden;
    width: 100%;
    position: relative;
  }

  .marquee-inner {
    display: flex;
    gap: var(--space-3);
    width: max-content;
    animation: marquee-scroll 55s linear infinite;
  }

  .marquee-inner .logo-chip { flex-shrink: 0; }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-inner { animation: none; justify-content: center; flex-wrap: wrap; }
  }

  .marquee-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    z-index: 2;
    pointer-events: none;
  }

  .marquee-fade--left {
    left: 0;
    background: linear-gradient(to right, var(--color-bg) 0%, transparent 100%);
  }

  .marquee-fade--right {
    right: 0;
    background: linear-gradient(to left, var(--color-bg) 0%, transparent 100%);
  }

  .logo-chip {
    background: #ffffff;
    border-radius: 12px;
    box-shadow:
      rgba(103, 103, 103, 0.08) 0px 0px 0px 1px,
      rgba(103, 103, 103, 0.08) 0px 2px 4px 0px;
    padding: 10px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .fin-chip {
    background: rgba(255, 255, 255, 0.3);
    box-shadow: none;
  }

  .fin-text {
    font-size: var(--text-sm);
    font-weight: 600;
    font-family: monospace;
    letter-spacing: 0.03em;
    white-space: nowrap;
    color: var(--c);
  }

  /* Integrations */
  .integrations-inner {
    padding: var(--space-12) var(--space-8);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-6);
    border-radius: var(--radius-lg);
  }

  .integrations-inner h2 {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .integrations-inner p {
    max-width: 50ch;
    margin: 0;
  }

  .integration-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
    margin-top: var(--space-2);
  }

  .integration-tag {
    padding: 6px 16px;
    border-radius: var(--radius-full);
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--color-border);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    transition: border-color var(--duration-fast), color var(--duration-fast);
  }

  .integration-tag:hover {
    border-color: var(--color-border-strong);
    color: var(--color-text-primary);
  }

  /* Screen-reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Features list ───────────────────────────────────────── */
  .feat-list {
    padding: var(--space-4) 0 var(--space-16);
  }
  .feat-row {
    display: flex;
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
    max-width: 1100px;
    margin: 0 auto var(--space-16);
    padding: 0 var(--space-6);
  }
  .feat-row--alt {
    flex-direction: row-reverse;
  }
  .feat-media {
    flex: 0 0 48%;
    border-radius: 20px;
    overflow: hidden;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    min-height: 240px;
  }
  .feat-svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .feat-body {
    flex: 1;
    min-width: 0;
  }
  .feat-name {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 var(--space-4);
    color: var(--color-text);
  }
  .feat-desc {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text);
    margin: 0 0 var(--space-5);
    max-width: 46ch;
  }
  .feat-pills {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .feat-pills li {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .feat-pills li::before {
    content: '—';
    color: var(--color-accent);
    font-weight: 700;
    flex-shrink: 0;
  }
  .feat-divider {
    width: 1px;
    height: 64px;
    background: linear-gradient(to bottom, transparent, var(--color-accent), transparent);
    margin: 0 auto var(--space-4);
  }

  /* Strip CTA card background on this page */
  :global(.cta-section .cta-inner) {
    background: transparent;
    border: none;
    box-shadow: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }
  :global(.cta-section .cta-glow) {
    display: none;
  }

  @media (max-width: 768px) {
    .feat-row,
    .feat-row--alt {
      flex-direction: column;
      gap: var(--space-6);
      margin-bottom: var(--space-12);
    }
    .feat-media {
      flex: unset;
      width: 100%;
      min-height: 200px;
    }
    .feat-desc { max-width: 100%; }
  }
</style>
